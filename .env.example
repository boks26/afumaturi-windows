# URL-ul de baza al backend-ului Drupal, fara slash la final.
VITE_API_BASE_URL=https://afumaturi-be.ddev.site

# Calea API-ului custom Drupal. Se modifica daca routing.yml foloseste alta baza.
VITE_API_PATH=/api/v1

# Timeout pentru cereri, in milisecunde.
VITE_API_TIMEOUT_MS=15000

# Aplicatia OAuth configurata in Drupal Simple OAuth.
VITE_OAUTH_CLIENT_ID=
VITE_OAUTH_CLIENT_SECRET=

# Client secret este acceptat aici doar pentru dezvoltarea locala. Variabilele VITE_*
# sunt incluse in aplicatia compilata; pentru productie folositi un client OAuth public
# (PKCE) sau un serviciu intermediar, nu distribuiti un secret real in installer.
