# URL-ul de baza al backend-ului Drupal, fara slash la final.
VITE_API_BASE_URL=https://afumaturi-api.duckdns.org

# Calea API-ului custom Drupal. Se modifica daca routing.yml foloseste alta baza.
VITE_API_PATH=/api/v1

# Timeout pentru cereri, in milisecunde.
VITE_API_TIMEOUT_MS=15000

# Clientul OAuth public comun pentru WEB si Windows.
VITE_OAUTH_CLIENT_ID=afumaturi_public
VITE_OAUTH_CLIENT_SECRET=

# Variabilele VITE_* sunt incluse in aplicatia compilata. Nu adaugati un secret real.
